generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  password  String
  role      String   @default("user")
  language  String   @default("fr")
  createdAt DateTime @default(now())

  transactions        PaymentTransaction[]
  personalizationSlot PersonalizationSlot?
  customizations      Customization[]
  aidRequests         AidRequest[]
  posts               Post[]
  comments            Comment[]
}

model Book {
  id             String   @id @default(uuid())
  slug           String   @unique
  titleFr        String
  titleEn        String
  subtitleFr     String
  subtitleEn     String
  descriptionFr  String
  descriptionEn  String
  coverUrl       String   @default("")
  coverData      Bytes?
  coverMime      String?
  pdfData        Bytes?
  pdfFilename    String?
  hasPdf         Boolean  @default(false)
  priceEbook     Float    @default(6.99)
  pricePrint     Float    @default(14.99)
  paperAvailable Boolean  @default(false)
  orderIdx       Int      @default(0)
  createdAt      DateTime @default(now())
}

model PaymentTransaction {
  id            String   @id @default(uuid())
  sessionId     String   @unique
  userId        String
  userEmail     String
  amount        Float
  currency      String   @default("chf")
  itemType      String
  metadata      Json     @default("{}")
  paymentStatus String   @default("pending")
  status        String   @default("open")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model PersonalizationSlot {
  id        String    @id @default(uuid())
  userId    String    @unique
  available Boolean   @default(false)
  grantedAt DateTime  @default(now())
  usedAt    DateTime?

  user User @relation(fields: [userId], references: [id])
}

model Customization {
  id              String    @id @default(uuid())
  userId          String
  userEmail       String
  userName        String
  childName       String
  childAge        Int
  childTraits     String
  childInterests  String
  themeToWork     String
  additionalNotes String    @default("")
  status          String    @default("pending")
  pdfData         Bytes?
  pdfFilename     String?
  createdAt       DateTime  @default(now())
  deliveredAt     DateTime?
  updatedAt       DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model AidRequest {
  id                    String    @id @default(uuid())
  userId                String
  userEmail             String
  userName              String
  familySituation       String
  organism              String
  organismOther         String    @default("")
  childDifficulties     String
  country               String
  monthlyIncomeRange    String    @default("")
  justificationData     Bytes?
  justificationMime     String    @default("application/octet-stream")
  justificationFilename String    @default("justificatif")
  status                String    @default("pending")
  grantedBookIds        String[]  @default([])
  adminNote             String    @default("")
  createdAt             DateTime  @default(now())
  approvedAt            DateTime?
  rejectedAt            DateTime?

  user User @relation(fields: [userId], references: [id])
}

model Post {
  id        String    @id @default(uuid())
  userId    String
  userName  String
  title     String
  content   String
  status    String    @default("pending")
  createdAt DateTime  @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: NoAction)
  comments Comment[]
}

model Comment {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  userName  String
  content   String
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: NoAction)
}

model Event {
  id            String   @id @default(uuid())
  titleFr       String
  titleEn       String
  descriptionFr String
  descriptionEn String
  date          DateTime
  location      String
  online        Boolean  @default(false)
  link          String   @default("")
  createdAt     DateTime @default(now())
}

model Settings {
  id                String @id @default("global")
  whatsappLinkFr    String @default("")
  whatsappLinkEn    String @default("")
  bundlePrice       Float  @default(69.99)
  personalizedPrice Float  @default(24.99)
  shippingCh        Float  @default(5.00)
  shippingEu        Float  @default(10.00)
  shippingWorld     Float  @default(15.00)
  openaiKey         String @default("")
  claudeKey         String @default("")
  geminiKey         String @default("")
  guideData         Bytes?
  guideName         String?
}

model QuizResult {
  id        String   @id @default(uuid())
  userId    String
  answers   Json
  createdAt DateTime @default(now())
}
